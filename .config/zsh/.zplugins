#
# .zplugins.txt - antidote plugins file
#

# Load near the top so you get p10k's instaprompt if you need it.
#$ZSH_CUSTOM path:plugins/p10k-instaprompt
#mattmc3/zfunctions
$ZSH_CUSTOM path:plugins/xdg

# Custom
$ZSH_CUSTOM path:plugins/abbreviations
$ZSH_CUSTOM path:plugins/git
#$ZSH_CUSTOM path:plugins/golang
#$ZSH_CUSTOM path:plugins/otp
$ZSH_CUSTOM path:plugins/python

# Utils
#romkatv/zsh-bench kind:path
#ohmyzsh/ohmyzsh path:plugins/extract

# Editor
#ohmyzsh/ohmyzsh path:plugins/magic-enter
#ohmyzsh/ohmyzsh path:plugins/fancy-ctrl-z

# macOS
#ohmyzsh/ohmyzsh pathoth:plugins/iterm2 conditional:is-macos
#zshzoo/macos conditional:is-macos

# Prompt
sindresorhus/pure kind:fpath
romkatv/powerlevel10k kind:fpath

#
# Regular plugins
#

#mattmc3/zman
#lukechilds/zsh-nvm

# add even more completions
zsh-users/zsh-completions kind:fpath path:src
mattmc3/zephyr path:plugins/completion

zsh-users/zsh-syntax-highlighting
zsh-users/zsh-autosuggestions
zsh-users/zsh-history-substring-search

